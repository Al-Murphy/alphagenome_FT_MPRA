{
  "_comment": "Optimal hyperparameters for Gosai 2024 episomal MPRA, SK-N-SH cell line. 200bp sequences, chr-based splits.",
  "_source": "Adapted from mpra_K562.json benchmark results",

  "cell_type": "SKNSH",

  "data": {
    "batch_size": 64,
    "random_shift": true,
    "random_shift_likelihood": 0.5,
    "max_shift": 10,
    "reverse_complement": true,
    "reverse_complement_likelihood": 0.5,
    "pad_n_bases": 0
  },

  "model": {
    "init_seq_len": 200,
    "center_bp": 256,
    "pooling_type": "flatten",
    "nl_size": "512,512",
    "do": 0.1,
    "activation": "relu"
  },

  "training": {
    "num_epochs": 100,
    "learning_rate": 1e-3,
    "optimizer": "adam",
    "weight_decay": 1e-6,
    "gradient_accumulation_steps": 1,
    "gradient_clip": null,
    "lr_scheduler": null,
    "no_val_split": false,
    "early_stopping_patience": 5,
    "val_eval_frequency": 4,
    "test_eval_frequency": 4
  },

  "two_stage": {
    "enabled": true,
    "second_stage_lr": 1e-05,
    "second_stage_epochs": 50
  },

  "cached_embeddings": {
    "use_cached_embeddings": false,
    "cache_file": null
  },

  "checkpointing": {
    "checkpoint_dir": "./results/models/checkpoints/episomal/"
  },

  "wandb": {
    "enabled": true,
    "project": "alphagenome-episomal-mpra",
    "wandb_name": "episomal-SKNSH-optimal"
  },

  "base_checkpoint_path": null
}
