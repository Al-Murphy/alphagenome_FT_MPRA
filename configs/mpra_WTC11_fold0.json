{
  "_comment": "WTC11 LentiMPRA, fine-tuned on the AlphaGenome fold-0 single-fold backbone. Same optimal hyperparameters as mpra_WTC11.json; differs only in backbone (fold_0) and a genomically-filtered test set (LegNet test fold restricted to AG fold-0 held-out TEST regions).",
  "_source": "mpra_WTC11.json (optimal) + fold_0 backbone",

  "cell_type": "WTC11",

  "data": {
    "batch_size": 128,
    "random_shift": true,
    "random_shift_likelihood": 0.5,
    "reverse_complement": true,
    "pad_n_bases": 0
  },

  "model": {
    "center_bp": 256,
    "pooling_type": "flatten",
    "nl_size": "1024",
    "do": 0.3,
    "activation": "relu"
  },

  "training": {
    "num_epochs": 100,
    "learning_rate": 1e-3,
    "optimizer": "adam",
    "weight_decay": 1e-6,
    "gradient_accumulation_steps": 1,
    "gradient_clip": null,
    "lr_scheduler": null,
    "no_val_split": false,
    "early_stopping_patience": 5,
    "val_eval_frequency": 4,
    "test_eval_frequency": 4
  },

  "two_stage": {
    "enabled": true,
    "second_stage_lr": 1e-05,
    "second_stage_epochs": 50
  },

  "cached_embeddings": {
    "use_cached_embeddings": false,
    "cache_file": null
  },

  "checkpointing": {
    "checkpoint_dir": "./results/models/checkpoints/"
  },

  "wandb": {
    "enabled": true,
    "project": "alphagenome-mpra",
    "wandb_name": "mpra-WTC11-fold0"
  },

  "base_checkpoint_path": null,
  "base_model_version": "fold_0",
  "ag_test_filter_version": "fold_0",
  "fold_intervals_path": "./data/alphagenome_folds/sequences_human.bed.gz"
}
